# Copy this file to .env and fill in real values.
# Never commit .env.

# --- Required ---

# Used to sign auth tokens. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# --- Optional ---

NODE_ENV=production
PORT=3000

# Set to "true" to allow new accounts to sign up via /register.
# Leave "false" in production. Use the create-user CLI to add users.
ALLOW_REGISTRATION=false

# Cloudflare Tunnel token (only needed if running with docker compose).
# Create one at: https://one.dash.cloudflare.com/ -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Override only if you need to. Default is server/data/app.db relative to the repo.
# DATABASE_PATH=
